DOLA_DATA_DIR=/var/lib/dola-fetch-service
DOLA_CONFIG_PATH=/var/lib/dola-fetch-service/config.json
DOLA_DEFAULT_PROXY_API_URL=https://example.com/get-proxy?num=1&type=txt
DOLA_DATABASE_URL=postgresql://dola:change-me@127.0.0.1:5432/dola
DOLA_QUEUE_BACKEND=redis
DOLA_REDIS_URL=redis://127.0.0.1:6379/0
DOLA_QUEUE_NAMESPACE=dola:tasks
DOLA_QUEUE_VISIBILITY_TIMEOUT=180
DOLA_PORT=8088
DOLA_IMAGE_NAME=dola-fetch-service
DOLA_IMAGE_TAG=1.4.3
POSTGRES_DB=dola
POSTGRES_USER=dola
POSTGRES_PASSWORD=change-me
DOLA_ADMIN_USERNAME=admin
DOLA_ADMIN_PASSWORD=change-me-now
DOLA_PLATFORM_RATE_PER_MINUTE=30
DOLA_PLATFORM_BURST=5
DOLA_CIRCUIT_FAILURE_THRESHOLD=5
DOLA_CIRCUIT_RECOVERY_SECONDS=60
DOLA_QUEUE_HIGH_WATERMARK=1000
DOLA_MEMORY_HIGH_RATIO=0.80
DOLA_MEMORY_CRITICAL_RATIO=0.92
DOLA_MINIMUM_WORKERS=1
DOLA_MAX_EFFECTIVE_WORKERS=32
DOLA_RESULT_POLL_CONCURRENCY=16
DOLA_RESULT_POLL_RATE_PER_SECOND=8
DOLA_RESULT_POLL_BATCH_SIZE=256
DOLA_RESULT_POLL_INTERVAL_SECONDS=20
DOLA_API_MEMORY_LIMIT=1G
DOLA_WORKER_MEMORY_LIMIT=10G
DOLA_WORKER_SHM_SIZE=1gb

DEPLOY_HOST=your.server.ip
DEPLOY_USER=root
DEPLOY_PASSWORD=change-me
